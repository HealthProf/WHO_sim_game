# Postgres connection string. Locally this points at a Postgres you're
# running yourself; in production it's the connection string from your
# Neon (or other Postgres) database. If the URL contains "neon.tech",
# lib/db/index.ts automatically switches to Neon's HTTP driver instead of a
# raw TCP pool — no other config needed either way.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whosim

# Session signing secret. Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Only needed for local dev running `next start` (production build) outside
# `next dev` — tells NextAuth to trust the request's Host header. Not needed
# on Vercel (it trusts its own host automatically) and not needed for
# `npm run dev`.
# AUTH_TRUST_HOST=true

# Optional. Vercel sets this automatically when you add a cron job in the
# dashboard — only set it yourself if you're calling /api/cron/deadlines
# from somewhere Vercel doesn't manage.
# CRON_SECRET=
